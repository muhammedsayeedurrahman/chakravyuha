# Sarvam AI API Key (required for voice features)
SARVAM_API_KEY=your_sarvam_api_key_here

# ── LLM Provider Priority (first available wins) ──
# Options: gemini, mistral, openrouter, ollama, sarvam
LLM_PRIORITY=gemini,mistral,openrouter,ollama,sarvam

# ── Provider API Keys (set the ones you have) ──
# GEMINI_API_KEY=your_gemini_key_here
# MISTRAL_API_KEY=your_mistral_key_here
# OPENROUTER_API_KEY=your_openrouter_key_here

# ── Provider Models (override defaults) ──
# GEMINI_MODEL=gemini-2.0-flash
# MISTRAL_MODEL=mistral-small-latest
# OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct:free
# OLLAMA_MODEL=phi3
# SARVAM_LLM_MODEL=sarvam-m

# ── Ollama (local or remote device) ──
# OLLAMA_BASE_URL=http://192.168.1.100:11434

# Optional: Override defaults
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=1024
# CHROMA_PERSIST_DIR=./chromadb
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# GRADIO_PORT=7860
